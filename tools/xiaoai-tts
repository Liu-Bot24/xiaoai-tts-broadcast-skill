#!/usr/bin/env python3
"""Repository-root launcher for direct GitHub skill installs."""

import os
import sys


def main() -> None:
    script_dir = os.path.dirname(os.path.abspath(__file__))
    repo_dir = os.path.dirname(script_dir)
    tool = os.path.join(repo_dir, "xiaoai-tts", "tools", "xiaoai-tts")
    if not os.path.exists(tool):
        print(f"ERROR: nested tool not found: {tool}", file=sys.stderr)
        sys.exit(1)
    os.execv(sys.executable, [sys.executable, tool] + sys.argv[1:])


if __name__ == "__main__":
    main()
