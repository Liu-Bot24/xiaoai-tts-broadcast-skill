#!/usr/bin/env python3
"""
XiaoAI TTS Tool - 统一的小爱音箱控制工具
"""
import argparse
import shutil
import subprocess
import sys
import os

DEFAULT_SCOPE = "feishu-default"

# 获取脚本目录
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
BASE_DIR = os.path.dirname(SCRIPT_DIR)
SCRIPTS_DIR = os.path.join(BASE_DIR, "scripts")


def configure_stdio():
    """Keep Windows service logs from failing on Chinese output."""
    for stream_name in ("stdout", "stderr"):
        stream = getattr(sys, stream_name, None)
        if hasattr(stream, "reconfigure"):
            stream.reconfigure(encoding="utf-8", errors="replace")


def python_command():
    """Return a Python command that works across Linux, macOS, and Windows."""
    if sys.executable:
        return [sys.executable]
    for candidate in ("python3", "python"):
        if shutil.which(candidate):
            return [candidate]
    if os.name == "nt" and shutil.which("py"):
        return ["py", "-3"]
    return ["python3"]

def run_script(script_name, args_list, capture=True):
    """运行指定的 Python 脚本"""
    script_path = os.path.join(SCRIPTS_DIR, script_name)
    if not os.path.exists(script_path):
        print(f"错误: 脚本不存在 {script_path}", file=sys.stderr)
        return None, "", "脚本不存在", 1
    
    cmd = python_command() + [script_path] + args_list
    env = os.environ.copy()
    env.setdefault("PYTHONIOENCODING", "utf-8:replace")
    
    if capture:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            encoding="utf-8",
            errors="replace",
            env=env,
        )
        return result, result.stdout, result.stderr, result.returncode
    else:
        result = subprocess.run(cmd, env=env)
        return result, "", "", result.returncode


def print_captured(stdout, stderr):
    if stdout:
        print(stdout, end="")
    if stderr:
        print(stderr, end="", file=sys.stderr)

def main():
    configure_stdio()
    parser = argparse.ArgumentParser(
        description="XiaoAI TTS 控制工具",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  xiaoai-tts tts "你好，小爱"           # 语音播报（优先 Doubao，失败回退小爱 TTS）
  xiaoai-tts tts "你好" -s zh_female_xiaohe_uranus_bigtts  # 指定音色
  xiaoai-tts tts "你好" --speed 1.2     # 调整语速
  xiaoai-tts tts "好耶" -m happy        # 开心语气
  xiaoai-tts text "你好"                # 强制使用小爱自带 TTS
  xiaoai-tts broadcast "很长的文本..."   # 分段顺序播报长文本
  xiaoai-tts mode on --scope feishu     # 开启播报模式
  xiaoai-tts handle "正文" --scope feishu # 处理飞书消息：开启/退出/转发/忽略
  cat story.txt | xiaoai-tts broadcast --stdin
  xiaoai-tts wakeup                     # 唤醒小爱
  xiaoai-tts status                     # 获取播放状态
  xiaoai-tts health                     # 检查服务健康
  xiaoai-tts file /path/to/audio.mp3    # 播放本地文件
  xiaoai-tts url "http://example.com/audio.mp3"  # 播放远程音频
  xiaoai-tts voices -v 2.0              # 列出音色
        """
    )
    
    subparsers = parser.add_subparsers(dest='command', help='可用命令')
    
    # tts 命令 - 优先 Doubao，失败回退 text
    tts_parser = subparsers.add_parser('tts', help='语音播报（优先 Doubao TTS，失败自动回退小爱 TTS）')
    tts_parser.add_argument('content', help='要播放的文字内容')
    tts_parser.add_argument('--speaker', '-s', default='', 
                            help='音色名称（默认: 服务端默认')
    tts_parser.add_argument('--speed', type=float, default=1.0, help='语速（0.8-2.0，默认: 1.0）')
    tts_parser.add_argument('--emotion', '-e', help='情感（仅多情感音色支持）')
    tts_parser.add_argument('--mood', '-m', help='语气/情感别名（同 --emotion）')
    tts_parser.add_argument('--context', '-c', help='上下文指令')
    tts_parser.add_argument('--blocking', '-b', action='store_true', help='阻塞模式')
    tts_parser.add_argument('--timeout', '-t', type=int, default=60000, help='超时时间（毫秒）')
    
    # text 命令 - 小爱自带 TTS（备用）
    text_parser = subparsers.add_parser('text', help='使用小爱自带 TTS 播放（备用方案）')
    text_parser.add_argument('content', help='要播放的文字内容')
    text_parser.add_argument('--blocking', '-b', action='store_true', help='阻塞模式（等待播放完成）')
    text_parser.add_argument('--timeout', '-t', type=int, default=60000, help='超时时间（毫秒）')

    # broadcast 命令 - 长文本分段播报
    broadcast_parser = subparsers.add_parser('broadcast', help='长文本分段顺序播报（小爱自带 TTS）')
    broadcast_parser.add_argument('content', nargs='?', help='要播报的文字内容；长文本建议使用 --file 或 --stdin')
    broadcast_parser.add_argument('--file', '-f', help='从 UTF-8 文本文件读取内容')
    broadcast_parser.add_argument('--stdin', action='store_true', help='从标准输入读取内容')
    broadcast_parser.add_argument('--max-chars', type=int, default=450, help='每段最大字数（默认 450）')
    broadcast_parser.add_argument('--timeout', '-t', type=int, default=600000, help='每段超时时间（毫秒，默认 600000）')
    broadcast_parser.add_argument('--pause', type=float, default=0.4, help='分段间隔秒数（默认 0.4）')

    # mode 命令 - 有状态播报模式
    mode_parser = subparsers.add_parser('mode', help='开启、关闭或查看小爱播报模式')
    mode_parser.add_argument('mode', choices=['on', 'off', 'status'], help='模式操作')
    mode_parser.add_argument('--scope', default=DEFAULT_SCOPE, help='状态作用域，建议使用飞书会话 ID')
    mode_parser.add_argument('--json', action='store_true', help='输出 JSON')

    # handle 命令 - 对单条聊天消息做状态机处理
    handle_parser = subparsers.add_parser('handle', help='处理聊天消息：识别启动/退出/转发/忽略')
    handle_parser.add_argument('content', nargs='?', help='聊天消息正文')
    handle_parser.add_argument('--file', '-f', help='从 UTF-8 文本文件读取正文')
    handle_parser.add_argument('--stdin', action='store_true', help='从标准输入读取正文')
    handle_parser.add_argument('--scope', default=DEFAULT_SCOPE, help='状态作用域，建议使用飞书会话 ID')
    handle_parser.add_argument('--max-chars', type=int, default=450, help='每段最大字数（默认 450）')
    handle_parser.add_argument('--timeout', '-t', type=int, default=600000, help='每段超时时间（毫秒，默认 600000）')
    handle_parser.add_argument('--pause', type=float, default=0.4, help='分段间隔秒数（默认 0.4）')
    handle_parser.add_argument('--force', action='store_true', help='忽略模式状态，强制播报')
    handle_parser.add_argument('--dry-run', action='store_true', help='只判断动作，不实际播报')
    handle_parser.add_argument('--json', action='store_true', help='输出 JSON')

    # forward 命令 - 按当前模式状态转发正文
    forward_parser = subparsers.add_parser('forward', help='按当前播报模式状态转发正文给小爱')
    forward_parser.add_argument('content', nargs='?', help='聊天消息正文')
    forward_parser.add_argument('--file', '-f', help='从 UTF-8 文本文件读取正文')
    forward_parser.add_argument('--stdin', action='store_true', help='从标准输入读取正文')
    forward_parser.add_argument('--scope', default=DEFAULT_SCOPE, help='状态作用域，建议使用飞书会话 ID')
    forward_parser.add_argument('--max-chars', type=int, default=450, help='每段最大字数（默认 450）')
    forward_parser.add_argument('--timeout', '-t', type=int, default=600000, help='每段超时时间（毫秒，默认 600000）')
    forward_parser.add_argument('--pause', type=float, default=0.4, help='分段间隔秒数（默认 0.4）')
    forward_parser.add_argument('--force', action='store_true', help='忽略模式状态，强制播报')
    forward_parser.add_argument('--dry-run', action='store_true', help='只判断动作，不实际播报')
    forward_parser.add_argument('--json', action='store_true', help='输出 JSON')
    
    # control 命令
    wakeup_parser = subparsers.add_parser('wakeup', help='唤醒小爱音箱')
    wakeup_parser.add_argument('--silent', action='store_true', help='静默唤醒（不播放提示音）')
    
    subparsers.add_parser('status', help='获取音箱播放状态')
    subparsers.add_parser('health', help='检查服务健康状态')
    
    # file 命令
    file_parser = subparsers.add_parser('file', help='播放本地音频文件')
    file_parser.add_argument('path', help='本地音频文件路径')
    
    # url 命令
    url_parser = subparsers.add_parser('url', help='播放远程音频 URL')
    url_parser.add_argument('url', help='远程音频 URL')
    
    # voices 命令
    voices_parser = subparsers.add_parser('voices', help='列出可用音色')
    voices_parser.add_argument('--version', '-v', choices=['1.0', '2.0'], help='仅显示指定版本的音色')
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        sys.exit(1)
    
    # 执行对应命令
    if args.command == 'tts':
        # 优先尝试 Doubao TTS
        cmd_args = [args.content]
        if args.speaker != '':
            cmd_args.extend(['--speaker', args.speaker])
        if args.speed != 1.0:
            cmd_args.extend(['--speed', str(args.speed)])
        # --mood 和 --emotion 都映射到 emotion 参数
        mood_or_emotion = args.mood or args.emotion
        if mood_or_emotion:
            cmd_args.extend(['--emotion', mood_or_emotion])
        if args.context:
            cmd_args.extend(['--context', args.context])
        if args.blocking:
            cmd_args.append('--blocking')
        if args.timeout != 60000:
            cmd_args.extend(['--timeout', str(args.timeout)])
        
        result, stdout, stderr, code = run_script('tts_doubao.py', cmd_args)
        
        if code == 0 and result and result.returncode == 0:
            print(stdout, end='')
            sys.exit(0)
        else:
            # Doubao 失败，回退到 text
            print_captured(stdout, stderr)
            print("WARN: Doubao TTS 失败，回退到小爱自带 TTS...", file=sys.stderr)
            text_args = [args.content]
            if args.blocking:
                text_args.append('--blocking')
            if args.timeout != 60000:
                text_args.extend(['--timeout', str(args.timeout)])
            sys.exit(run_script('play_text.py', text_args, capture=False)[3])
    
    elif args.command == 'text':
        cmd_args = [args.content]
        if args.blocking:
            cmd_args.append('--blocking')
        if args.timeout != 60000:
            cmd_args.extend(['--timeout', str(args.timeout)])
        sys.exit(run_script('play_text.py', cmd_args, capture=False)[3])

    elif args.command == 'broadcast':
        cmd_args = []
        if args.content:
            cmd_args.append(args.content)
        if args.file:
            cmd_args.extend(['--file', args.file])
        if args.stdin:
            cmd_args.append('--stdin')
        if args.max_chars != 450:
            cmd_args.extend(['--max-chars', str(args.max_chars)])
        if args.timeout != 600000:
            cmd_args.extend(['--timeout', str(args.timeout)])
        if args.pause != 0.4:
            cmd_args.extend(['--pause', str(args.pause)])
        sys.exit(run_script('broadcast_text.py', cmd_args, capture=False)[3])

    elif args.command == 'mode':
        cmd_args = ['mode', args.mode, '--scope', args.scope]
        if args.json:
            cmd_args.append('--json')
        sys.exit(run_script('broadcast_mode.py', cmd_args, capture=False)[3])

    elif args.command in ('handle', 'forward'):
        cmd_args = [args.command]
        if args.content:
            cmd_args.append(args.content)
        if args.file:
            cmd_args.extend(['--file', args.file])
        if args.stdin:
            cmd_args.append('--stdin')
        cmd_args.extend(['--scope', args.scope])
        if args.max_chars != 450:
            cmd_args.extend(['--max-chars', str(args.max_chars)])
        if args.timeout != 600000:
            cmd_args.extend(['--timeout', str(args.timeout)])
        if args.pause != 0.4:
            cmd_args.extend(['--pause', str(args.pause)])
        if args.force:
            cmd_args.append('--force')
        if args.dry_run:
            cmd_args.append('--dry-run')
        if args.json:
            cmd_args.append('--json')
        sys.exit(run_script('broadcast_mode.py', cmd_args, capture=False)[3])
    
    elif args.command == 'wakeup':
        cmd_args = ['wakeup']
        if args.silent:
            cmd_args.append('--silent')
        sys.exit(run_script('control.py', cmd_args, capture=False)[3])

    elif args.command == 'status':
        sys.exit(run_script('control.py', ['status'], capture=False)[3])

    elif args.command == 'health':
        sys.exit(run_script('control.py', ['health'], capture=False)[3])

    elif args.command == 'file':
        sys.exit(run_script('play_file.py', [args.path], capture=False)[3])

    elif args.command == 'url':
        sys.exit(run_script('play_url.py', [args.url], capture=False)[3])
    
    elif args.command == 'voices':
        cmd_args = []
        if args.version:
            cmd_args.extend(['--version', args.version])
        sys.exit(run_script('list_doubao_voices.py', cmd_args, capture=False)[3])

if __name__ == '__main__':
    main()
